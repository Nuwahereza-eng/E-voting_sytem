# Bridge configuration
PORT=4000

# Soroban / Stellar
CONTRACT_ID=
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Registry file: JSON map of msisdn -> { publicKey, secret, memberIndex }
# The 'secret' is a custodial S... key held by the bridge. This is a
# hackathon simplification — see AGENT_BUILD_BRIEF.md §6.
REGISTRY_PATH=./data/registry.json

# Members file: JSON array of Stellar public keys, in the exact order
# used when the community's Merkle root was computed. Used to build
# proofs for USSD/SMS voters.
MEMBERS_PATH=./data/members.json

# When set, the bridge will attempt to send a confirmation SMS back
# to the voter via Africa's Talking. Leave empty to disable.
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

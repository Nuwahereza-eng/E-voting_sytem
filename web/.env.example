# Copy this file to `.env` and fill in the deployed contract ID.
VITE_CONTRACT_ID=
# Trust registry contract (SautiRegistry). Optional but recommended:
# when set, the /verify page shows a green badge for attested organisers.
VITE_REGISTRY_ID=
VITE_NETWORK=TESTNET
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional demo bootstrap: comma-separated G... member public keys
# (used by the admin dashboard to pre-fill a Merkle root).
VITE_DEMO_MEMBERS=

# USSD/SMS bridge base URL (Onboard & voter status use this).
# Local dev: http://localhost:4000 (run `npm run dev` in ussd-bridge/).
# Deployed:  https://sauti-bridge.onrender.com
# On Vercel: set this in Project Settings → Environment Variables, then redeploy.
VITE_BRIDGE_URL=http://localhost:4000
